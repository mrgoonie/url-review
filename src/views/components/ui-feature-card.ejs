<div class="glass-card p-6 md:p-8 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
  <% if (locals.icon) { %>
  <div class="feature-icon mb-4">
    <i class="<%= icon %> text-2xl text-brand-orange-500"></i>
  </div>
  <% } %>
  <h3 class="text-xl font-bold font-heading text-gray-900 dark:text-white mb-2"><%= title %></h3>
  <p class="text-gray-600 dark:text-gray-400"><%= description %></p>
</div>
