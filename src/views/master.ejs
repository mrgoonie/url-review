<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'en' %>" data-mode="dark">

<head>
  <%- include('common/head', locals) %>
  <script>
    (function() {
      const theme = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-mode', theme);
    })();
  </script>
</head>

<body class="min-h-screen bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-body antialiased">
  <% if (typeof locals.headerEnabled === 'undefined' || locals.headerEnabled) { %>
    <%- include('common/header', locals) %>
  <% } %>

  <main>
    <% if (typeof page !== 'undefined') { %>
      <%- include(page, locals) %>
    <% } %>
  </main>

  <% if (typeof locals.footerEnabled === 'undefined' || locals.footerEnabled) { %>
    <%- include('common/footer', locals) %>
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/dayjs@1/dayjs.min.js" defer></script>
  <script src="/js/marked.min.js" defer></script>
  <script src="https://unpkg.com/@popperjs/core@2" defer></script>
  <script src="https://unpkg.com/tippy.js@6" defer></script>

  <% if (locals.needsHighlight) { %>
  <script src="/vendor/highlight/highlight.min.js" defer></script>
  <% } %>
  <% if (locals.needsChart) { %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js" defer></script>
  <% } %>

  <script src="/assets/js/auth.js" defer></script>
  <script src="/js/scroll-animations.js" defer></script>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof tippy !== 'undefined') {
        tippy('.tippy', { animation: 'fade', duration: 200, interactive: true });
      }
    });
  </script>

  <% if (locals.pageScripts) { %>
    <% locals.pageScripts.forEach(function(script) { %>
      <script src="<%= script %>" defer></script>
    <% }) %>
  <% } %>
</body>

</html>
