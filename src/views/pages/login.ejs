<section class="min-h-[70vh] flex items-center justify-center py-12">
  <div class="section-container">
    <div class="max-w-md mx-auto">
      <div class="glass-card p-8 md:p-10">
        <div class="text-center mb-8">
          <div class="w-14 h-14 rounded-2xl gradient-bg flex items-center justify-center mx-auto mb-4">
            <i class="ri-lock-line text-2xl text-white"></i>
          </div>
          <h1 class="text-2xl font-heading font-bold text-gray-900 dark:text-white mb-2"><%= typeof t === 'function' ? t('login.title') : 'Sign In' %></h1>
          <p class="text-gray-600 dark:text-gray-400 text-sm"><%= typeof t === 'function' ? t('login.subtitle') : 'Sign in to access your dashboard and API keys' %></p>
        </div>
        <div class="space-y-3">
          <a href="/login/github" class="flex items-center justify-center gap-3 w-full px-5 py-3.5 rounded-xl font-medium no-underline bg-gray-900 dark:bg-gray-700 hover:bg-gray-800 dark:hover:bg-gray-600 text-white transition-colors">
            <i class="ri-github-fill text-xl"></i> <%= typeof t === 'function' ? t('login.githubBtn') : 'Sign in with GitHub' %>
          </a>
          <a href="/login/google" class="flex items-center justify-center gap-3 w-full px-5 py-3.5 rounded-xl font-medium no-underline bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
            <svg class="w-5 h-5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            <%= typeof t === 'function' ? t('login.googleBtn') : 'Sign in with Google' %>
          </a>
        </div>
        <div class="mt-6 text-center">
          <a href="<%= typeof localePath === 'function' ? localePath('/') : '/' %>" class="text-sm text-gray-500 hover:text-brand-orange-500 transition-colors no-underline">
            <i class="ri-arrow-left-line mr-1"></i> <%= typeof t === 'function' ? t('login.backHome') : 'Back to Home' %>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
