<%- include('../components/breadcrumbs', { crumbs: [{ label: t('nav.home'), path: '/' }, { label: t('profile.title') }] }) %>

<section class="py-8 md:py-12">
  <div class="section-container">
    <div class="max-w-4xl mx-auto">
      <div class="mb-8">
        <h1 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 dark:text-white mb-2">
          <%= t('nav.hi') %>, <strong><%- user.name %></strong>!
        </h1>
        <p class="text-gray-600 dark:text-gray-400"><%= t('profile.title') %></p>
      </div>

      <!-- Current Plan -->
      <div class="glass-card p-6 md:p-8 mb-8">
        <h2 class="text-xl font-heading font-bold text-gray-900 dark:text-white mb-6 flex items-center">
          <i class="ri-price-tag-3-line mr-2 text-brand-orange-500"></i> <%= t('profile.plan') %>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <% locals.plans.forEach(function(plan) { %>
          <% const isCurrentPlan = locals.userPlan && locals.userPlan.planId === plan.id; %>
          <div class="rounded-xl border p-4 transition-all
            <%= isCurrentPlan ? 'border-brand-orange-500 bg-brand-orange-500/5' : 'border-gray-200 dark:border-gray-700' %>">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-heading font-bold text-gray-900 dark:text-white"><%- plan.name %></h3>
              <% if (isCurrentPlan) { %>
              <span class="badge-primary text-xs"><i class="ri-check-line mr-1"></i>Active</span>
              <% } %>
            </div>
            <div class="text-2xl font-bold text-gray-900 dark:text-white mb-1">$<%- plan.price / 100 %> <span class="text-sm font-normal text-gray-500"><%- plan.currency %></span></div>
            <p class="text-xs text-gray-500 mb-3"><%= t('pricing.perMonth') %></p>
            <% if (!isCurrentPlan) { %>
            <a href="<%- plan.checkoutUrl %>" class="block w-full text-center btn-secondary text-sm no-underline py-2">
              <i class="ri-arrow-up-line mr-1"></i> Upgrade
            </a>
            <% } %>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- API Keys -->
      <div class="glass-card p-6 md:p-8 mb-8">
        <h2 class="text-xl font-heading font-bold text-gray-900 dark:text-white mb-6 flex items-center">
          <i class="ri-key-2-line mr-2 text-brand-orange-500"></i> <%= t('profile.apiKeys') %>
        </h2>
        <script>
          function createNewApiKey() {
            const name = document.getElementById("api-key-name").value;
            fetch("/api/v1/api_key", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ name }) })
              .then(res => res.json())
              .then(data => { if (data.success) { location.reload(); } else { console.error(data.message); } });
          }
          function deleteApiKey(id) {
            fetch('/api/v1/api_key/' + id, { method: "DELETE", headers: { "Content-Type": "application/json" } })
              .then(res => res.json())
              .then(data => { if (data.success) { location.reload(); } else { console.error(data.message); } });
          }
        </script>
        <div class="flex gap-2 mb-4">
          <input class="input-field flex-grow" type="text" id="api-key-name" placeholder="API key name" />
          <button class="btn-primary whitespace-nowrap" onclick="createNewApiKey()">
            <i class="ri-add-line mr-1"></i> <%= t('profile.createKey') %>
          </button>
        </div>
        <% if (locals.apiKeys && locals.apiKeys.length > 0) { %>
        <ul class="space-y-3">
          <% locals.apiKeys.forEach(function(apiKey, index) { %>
          <li class="flex items-center justify-between p-3 rounded-xl border border-gray-200 dark:border-gray-700 gap-3">
            <div class="flex-grow min-w-0">
              <p class="font-medium text-gray-900 dark:text-white text-sm truncate"><%- apiKey.name %></p>
              <p class="text-xs text-gray-500"><%- apiKey.displayCreatedAt %></p>
              <%- include('../common/link-copy', { link: apiKey.key }) %>
            </div>
            <button class="btn-ghost text-red-500 hover:text-red-600 p-2 flex-shrink-0" onclick="deleteApiKey('<%- apiKey.id %>')">
              <i class="ri-delete-bin-line"></i>
            </button>
          </li>
          <% }) %>
        </ul>
        <% } else { %>
        <p class="text-gray-500 dark:text-gray-400 text-sm text-center py-4"><%= t('profile.noKeys') %></p>
        <% } %>
      </div>

      <!-- Actions -->
      <div class="flex gap-3 justify-center">
        <a href="/logout" class="btn-ghost text-red-500 no-underline">
          <i class="ri-logout-box-line mr-1"></i> <%= t('nav.logout') %>
        </a>
        <a href="<%= localePath('/') %>" class="btn-secondary no-underline">
          <i class="ri-home-line mr-1"></i> <%= t('nav.home') %>
        </a>
      </div>
    </div>
  </div>
</section>
