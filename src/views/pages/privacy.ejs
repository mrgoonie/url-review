<%- include('../components/breadcrumbs', { crumbs: [{ label: typeof t === 'function' ? t('nav.home') : 'Home', path: '/' }, { label: typeof t === 'function' ? t('footer.privacy') : 'Privacy Policy' }] }) %>

<section class="py-12 md:py-20">
  <div class="section-container">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 dark:text-white mb-8">
        <%= typeof t === 'function' ? t('footer.privacy') : 'Privacy Policy' %>
      </h1>
      <div class="glass-card p-6 md:p-8">
        <div class="space-y-6 text-gray-600 dark:text-gray-400 leading-relaxed text-left">
          <p>Last updated: <%= new Date().toISOString().split('T')[0] %></p>
          <p>At ReviewWeb.site, we are committed to protecting your privacy and ensuring the security of your personal information.</p>

          <h3 class="text-lg font-heading font-semibold text-gray-900 dark:text-white">1. Information We Collect</h3>
          <ul class="list-disc list-inside space-y-1">
            <li>Personal Information: name, email address, and account details</li>
            <li>Usage Data: how you interact with our platform</li>
            <li>Device and Technical Information: IP address, browser type, device details</li>
          </ul>

          <h3 class="text-lg font-heading font-semibold text-gray-900 dark:text-white">2. How We Use Your Information</h3>
          <ul class="list-disc list-inside space-y-1">
            <li>To provide website analysis and review services</li>
            <li>To process payments and manage subscriptions</li>
            <li>To improve and personalize the platform</li>
            <li>To communicate service updates and notifications</li>
          </ul>

          <h3 class="text-lg font-heading font-semibold text-gray-900 dark:text-white">3. Data Security</h3>
          <p>We implement robust security measures including encryption, secure payment gateways, and regular security audits.</p>

          <h3 class="text-lg font-heading font-semibold text-gray-900 dark:text-white">4. Your Rights</h3>
          <p>You have the right to access, correct, or delete your personal information. Contact our support team to exercise these rights.</p>

          <h3 class="text-lg font-heading font-semibold text-gray-900 dark:text-white">5. Cookies</h3>
          <p>We use cookies for language preferences, authentication, and analytics. You can manage cookie preferences through your browser settings.</p>

          <h3 class="text-lg font-heading font-semibold text-gray-900 dark:text-white">6. Contact</h3>
          <p>For privacy-related questions, reach us on <a href="https://x.com/goon_nguyen" class="text-brand-orange-500 hover:underline">Twitter/X</a>.</p>
        </div>
      </div>
    </div>
  </div>
</section>
