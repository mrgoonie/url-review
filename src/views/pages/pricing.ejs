<%- include('../components/breadcrumbs', { crumbs: [{ label: t('nav.home'), path: '/' }, { label: t('pricing.title') }] }) %>

<section class="py-12 md:py-20">
  <div class="section-container">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-gray-900 dark:text-white mb-4"><%= t('pricing.title') %></h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-xl mx-auto"><%= t('pricing.subtitle') %></p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto mb-16">
      <% locals.plans.forEach(function(plan, index) { %>
      <% const isRecommended = plan.name === "Starter"; %>
      <div class="relative glass-card overflow-hidden transition-all duration-300 hover:-translate-y-1
        <%= isRecommended ? 'ring-2 ring-brand-orange-500 shadow-xl shadow-brand-orange-500/10' : '' %>">
        <% if (isRecommended) { %>
        <div class="absolute top-0 right-0 bg-brand-orange-500 text-white text-xs font-bold px-3 py-1.5 rounded-bl-xl">
          <i class="ri-star-line mr-1"></i><%= t('pricing.recommended') %>
        </div>
        <% } %>
        <div class="p-6 md:p-8">
          <h3 class="text-xl font-heading font-bold text-gray-900 dark:text-white mb-2"><%- plan.name %></h3>
          <div class="flex items-baseline gap-1 mb-1">
            <span class="text-4xl font-heading font-bold text-gray-900 dark:text-white">$<%- plan.price / 100 %></span>
            <span class="text-sm text-gray-500 dark:text-gray-400"><%- plan.currency %></span>
          </div>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-6"><%= t('pricing.perMonth') %></p>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-6"><%- plan.description %></p>
          <ul class="space-y-3 mb-8">
            <% plan.benefits.forEach(function(benefit) { %>
            <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
              <i class="ri-check-line text-green-500 mt-0.5 flex-shrink-0"></i>
              <span><%- benefit %></span>
            </li>
            <% }) %>
          </ul>
          <a href="<%- plan.checkoutUrl %>" class="block w-full text-center no-underline py-3 rounded-xl font-semibold transition-all duration-200 <%= isRecommended ? 'btn-primary' : 'btn-secondary' %>">
            <%= t('pricing.getStarted') %> <i class="ri-arrow-right-line ml-1"></i>
          </a>
        </div>
      </div>
      <% }) %>
    </div>

    <%- include('../sections/pricing-faq-section', locals) %>
  </div>
</section>
