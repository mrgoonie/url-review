<section class="min-h-[60vh] flex items-center justify-center py-12">
  <div class="section-container text-center">
    <div class="glass-card max-w-lg mx-auto p-8 md:p-12">
      <div class="w-16 h-16 rounded-full bg-green-500/10 flex items-center justify-center mx-auto mb-6">
        <i class="ri-check-line text-3xl text-green-500"></i>
      </div>
      <h1 class="text-2xl font-heading font-bold text-gray-900 dark:text-white mb-4">
        <%= typeof t === 'function' ? t('checkout.success') : 'Payment Successful' %>
      </h1>
      <p class="text-gray-600 dark:text-gray-400 mb-6">You have successfully subscribed to the <strong><%= typeof plan !== 'undefined' ? plan.name : '' %></strong> plan.</p>
    </div>
  </div>
</section>
