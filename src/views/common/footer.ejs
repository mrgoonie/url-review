      <p class="text-sm text-gray-400">
        &copy; <%= new Date().getFullYear() %> ReviewWeb.site. <%= typeof t === 'function' ? t('footer.copyright') : 'All rights reserved.' %>
      </p>
      <p class="text-sm text-gray-400">
        <%= typeof t === 'function' ? t('footer.madeWith') : 'Made with love by' %> <a href="https://x.com/goon_nguyen" target="_blank" rel="noopener" class="text-brand-orange-500 hover:underline font-medium no-underline">@goon_nguyen</a>
