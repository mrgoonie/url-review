        <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
          <%= typeof t === 'function' ? t('footer.description') : 'AI-powered website analysis platform.' %>
        </p>
        <div class="flex gap-3">
          <a href="https://x.com/goon_nguyen" target="_blank" rel="noopener" class="w-9 h-9 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-gray-500 hover:text-brand-orange-500 hover:bg-brand-orange-500/10 transition-all no-underline">
            <i class="ri-twitter-x-line"></i>
