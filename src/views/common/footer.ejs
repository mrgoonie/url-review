        <ul class="space-y-2">
          <li><a href="<%= typeof localePath === 'function' ? localePath('/') : '/' %>" class="text-sm text-gray-500 dark:text-gray-400 hover:text-brand-orange-500 transition-colors no-underline"><%= typeof t === 'function' ? t('nav.home') : 'Home' %></a></li>
