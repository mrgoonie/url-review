      <div>
        <h4 class="font-heading font-semibold text-sm text-gray-900 dark:text-white uppercase tracking-wider mb-4"><%= typeof t === 'function' ? t('footer.legal') : 'Legal' %></h4>
        <ul class="space-y-2">
          <li><a href="<%= typeof localePath === 'function' ? localePath('/privacy') : '/privacy' %>" class="text-sm text-gray-500 dark:text-gray-400 hover:text-brand-orange-500 transition-colors no-underline"><%= typeof t === 'function' ? t('footer.privacy') : 'Privacy Policy' %></a></li>
          <li><a href="https://github.com/mrgoonie/url-review" target="_blank" rel="noopener" class="text-sm text-gray-500 dark:text-gray-400 hover:text-brand-orange-500 transition-colors no-underline"><%= typeof t === 'function' ? t('nav.contribute') : 'Contribute' %></a></li>
