<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title><%= locals.page_name ? locals.page_name + ' | ' : '' %><%= locals.site_name || 'ReviewWeb.site' %></title>
<meta name="description" content="<%= locals.description || (typeof t === 'function' ? t('meta.siteDescription') : 'AI-Powered Website Analysis Platform') %>" />

<% if (typeof lang !== 'undefined' && locals.clientEnv) { %>
<link rel="canonical" href="<%= locals.clientEnv.BASE_URL %>/<%= lang %><%= locals.path_name && locals.path_name !== '/' ? locals.path_name : '' %>" />
<% (locals.supportedLangs || ['en','vi']).forEach(function(l) { %>
<link rel="alternate" hreflang="<%= l %>" href="<%= locals.clientEnv.BASE_URL %>/<%= l %><%= locals.path_name && locals.path_name !== '/' ? locals.path_name : '' %>" />
<% }); %>
<link rel="alternate" hreflang="x-default" href="<%= locals.clientEnv.BASE_URL %>/en<%= locals.path_name && locals.path_name !== '/' ? locals.path_name : '' %>" />
<% } %>

<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#030712" />

<meta name="keywords" content="<%= locals.keywords || (typeof t === 'function' ? t('meta.siteKeywords') : 'website review') %>" />

<meta property="og:type" content="website" />
<% if (typeof lang !== 'undefined') { %>
<meta property="og:locale" content="<%= lang === 'vi' ? 'vi_VN' : 'en_US' %>" />
<% } %>
<meta property="og:title" content="<%= locals.page_name ? locals.page_name + ' | ' : '' %><%= locals.site_name || 'ReviewWeb.site' %>" />
<meta property="og:description" content="<%= locals.description || (typeof t === 'function' ? t('meta.siteDescription') : 'Website') %>" />
<meta property="og:image" content="<%= locals.image || (locals.clientEnv ? locals.clientEnv.BASE_URL + '/share.webp' : '/share.webp') %>" />
<meta property="og:url" content="<%= locals.url || (locals.clientEnv ? locals.clientEnv.BASE_URL : '') %>" />
<meta property="og:site_name" content="ReviewWeb.site" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="<%= locals.page_name ? locals.page_name + ' | ' : '' %><%= locals.site_name || 'ReviewWeb.site' %>" />
<meta name="twitter:description" content="<%= locals.description || (typeof t === 'function' ? t('meta.siteDescription') : 'Website') %>" />
<meta name="twitter:image" content="<%= locals.image || (locals.clientEnv ? locals.clientEnv.BASE_URL + '/share.webp' : '/share.webp') %>" />
<meta name="twitter:creator" content="@goon_nguyen" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.min.css" rel="stylesheet" />
<link rel="stylesheet" href="/css/style.css" />

<% if (locals.needsHighlight) { %>
<link rel="stylesheet" href="/vendor/highlight/github-dark-dimmed.min.css" />
<% } %>

<% if (locals.clientEnv && locals.clientEnv.NODE_ENV === 'production') { %>
<script async src="https://www.googletagmanager.com/gtag/js?id=G-T1CGG8M9P5"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-T1CGG8M9P5');
</script>
