<header class="sticky top-0 z-50 w-full bg-white/80 dark:bg-gray-950/80 backdrop-blur-lg border-b border-gray-200/50 dark:border-gray-800/50 transition-all duration-300">
  <div class="section-container">
    <div class="flex items-center justify-between h-16 md:h-18">
      <a href="<%= typeof localePath === 'function' ? localePath('/') : '/' %>" class="flex items-center gap-2 no-underline group">
        <div class="w-8 h-8 rounded-lg gradient-bg flex items-center justify-center">
          <i class="ri-rocket-line text-white text-lg"></i>
        </div>
        <span class="font-heading font-bold text-xl text-gray-900 dark:text-white group-hover:text-brand-orange-500 transition-colors">
          ReviewWeb<span class="text-brand-orange-500">.site</span>
        </span>
      </a>

      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        <%
          const navItems = [
            { key: 'home', path: '/', label: typeof t === 'function' ? t('nav.home') : 'Home' },
            { key: 'pricing', path: '/pricing', label: typeof t === 'function' ? t('nav.pricing') : 'Pricing' },
            { key: 'apiDocs', path: '/api-docs', label: typeof t === 'function' ? t('nav.apiDocs') : 'API Docs', noLang: true },
            { key: 'mcp', path: 'https://github.com/mrgoonie/reviewwebsite-mcp-server/', label: typeof t === 'function' ? t('nav.mcp') : 'MCP', external: true },
            { key: 'cli', path: 'https://github.com/mrgoonie/rws-cli', label: typeof t === 'function' ? t('nav.cli') : 'CLI', external: true, icon: 'ri-terminal-line' },
          ];
        %>
        <% navItems.forEach(function(item) { %>
          <a href="<%= item.external ? item.path : item.noLang ? item.path : (typeof localePath === 'function' ? localePath(item.path) : item.path) %>"
             class="px-3 py-2 rounded-lg text-sm font-medium transition-colors no-underline
               <%= (typeof path_name !== 'undefined' && path_name === item.path) ? 'text-brand-orange-500 bg-brand-orange-500/10' : 'text-gray-600 dark:text-gray-300 hover:text-brand-orange-500 hover:bg-gray-100 dark:hover:bg-gray-800' %>"
             <% if (item.external) { %>target="_blank" rel="noopener"<% } %>>
            <% if (item.icon) { %><i class="<%= item.icon %> mr-1"></i><% } %>
            <%= item.label %>
            <% if (item.external) { %><i class="ri-external-link-line text-xs ml-0.5 opacity-50"></i><% } %>
          </a>
        <% }) %>
      </nav>

      <div class="flex items-center gap-2">
        <% if (typeof t === 'function') { %>
        <%- include('../components/language-switcher', locals) %>
        <% } %>
        <%- include('../components/dark-mode-toggle') %>

        <% if (typeof user !== 'undefined' && user) { %>
          <a href="<%= typeof localePath === 'function' ? localePath('/profile') : '/profile' %>" class="btn-ghost text-sm no-underline hidden sm:flex">
            <i class="ri-user-line mr-1"></i> <%= user.name %>
          </a>
          <a href="/logout" class="btn-ghost text-sm text-red-500 hover:text-red-600 no-underline tippy" data-tippy-content="<%= typeof t === 'function' ? t('nav.logout') : 'Logout' %>">
            <i class="ri-logout-box-line"></i>
          </a>
        <% } else { %>
          <a href="<%= typeof localePath === 'function' ? localePath('/login') : '/login' %>" class="btn-primary text-sm no-underline hidden sm:flex">
            <%= typeof t === 'function' ? t('nav.getStarted') : 'Get Started' %> <i class="ri-arrow-right-line ml-1"></i>
          </a>
        <% } %>

        <button id="mobile-menu-btn" class="lg:hidden btn-ghost p-2" aria-label="Toggle menu" aria-expanded="false">
          <i class="ri-menu-line text-xl" id="menu-icon-open"></i>
          <i class="ri-close-line text-xl hidden" id="menu-icon-close"></i>
        </button>
      </div>
    </div>
  </div>

  <%- include('./mobile-menu', locals) %>
</header>
